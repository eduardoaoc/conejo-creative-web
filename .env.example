# URL pública del sitio (sin barra final). Usada para metadata, sitemap y canonical.
NEXT_PUBLIC_SITE_URL=https://conejocreative.com

# --- Integraciones futuras (aún no utilizadas) ---

# Envío de correo del formulario de contacto (Resend). Solo servidor: nunca exponer.
RESEND_API_KEY=

# Dirección que recibirá los mensajes del formulario de contacto.
CONTACT_EMAIL=

# Cloudflare Turnstile (anti-spam del formulario).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
